# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "Unix-style AI orchestrator and terminal dataflow pipeline"
description:
  "Enchiridion is a pure Unix dataflow CLI for interacting with LLMs. It parses plain-text Markdown session files, streams Server-Sent Events (SSE) directly to stdout, and dynamically augments context using the Exa search API. Designed strictly for editor integration and terminal command generation."
maintainer: ["Juan Bautista <deserd@protonmail.com>"]
authors: ["Juan Bautista <deserd@protonmail.com>"]
license: "MIT"
tags: ["cli" "ai" "llm" "exa" "search" "async"]
homepage: "https://github.com/and-rs/enchiridion"
bug-reports: "https://github.com/and-rs/enchiridion/issues"
depends: [
  "alcotest"
  "ocaml" {>= "5.4.1"}
  "dune" {>= "3.20" & >= "3.20.0"}
  "cohttp-eio"
  "eio_main"
  "ca-certs"
  "tls-eio"
  "yojson"
  "core"
  "core_unix"
  "mirage-crypto-rng-eio"
  "utop" {with-dev-setup & >= "2.16.0"}
  "ocamlformat" {with-dev-setup & = "0.28.1"}
  "ocaml-lsp-server" {with-dev-setup & >= "1.25.0"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/and-rs/enchiridion.git"
x-maintenance-intent: ["(latest)"]
